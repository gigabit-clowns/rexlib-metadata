{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "minimumReleaseAge": "14 days",
  "internalChecksFilter": "strict",
  "poetry": {
    "description": "Not a poetry project, but supersedes default pep manager if left enabled.",
    "enabled": false
  },
  "customManagers": [
    {
      "description": "Track maturin in [build-system].requires, which the poetry manager does not cover",
      "customType": "regex",
      "managerFilePatterns": [
        "/^pyproject\\.toml$/"
      ],
      "matchStrings": ["\"maturin==(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "maturin",
      "datasourceTemplate": "pypi"
    }
  ],
  "packageRules": [
    {
      "description": "Python version in CI matrix is a manual decision",
      "matchDepNames": ["python"],
      "enabled": false
    },
    {
      "description": "Security advisories bypass the 14-day delay",
      "matchUpdateTypes": ["security"],
      "minimumReleaseAge": "0 days"
    }
  ]
}
